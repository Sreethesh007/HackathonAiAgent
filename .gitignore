# ══════════════════════════════════════════════════════════════════════════════
#  Healthcare Triage Agent — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Secrets & Environment ─────────────────────────────────────────────────────

.env
secrets/
*.pem
*.key
*.cert

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*$py.class

# ── Virtual Environment ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Package Build Artifacts ───────────────────────────────────────────────────
*.egg-info/
*.egg
dist/
build/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
MANIFEST

# ── Test & Coverage ───────────────────────────────────────────────────────────
.coverage
coverage.xml
htmlcov/
.pytest_cache/
.tox/
.nox/
nosetests.xml
test-results/
junit.xml

# ── Type Checking & Linting ───────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ── Data Directories (local persistent storage) ───────────────────────────────
data/
data/chroma/
data/sessions/
data/failed_flows/

# ── Models (GGUF files are huge — never commit these) ─────────────────────────
models/
*.gguf
*.bin
*.safetensors
*.ggml

# ── Docs (auto-generated) ─────────────────────────────────────────────────────
docs/graph.md

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── OS Generated ──────────────────────────────────────────────────────────────
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ── Jupyter (if used for experiments) ────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Temporary Files ───────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
tmp/
temp/