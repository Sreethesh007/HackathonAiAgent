# ── LLM ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# ── Vector Store (local Chroma) ────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=medical_guidelines
EMBEDDING_MODEL=text-embedding-3-small   # or "local" to use sentence-transformers

# ── Session Memory ─────────────────────────────────────────────────────────
SESSION_DIR=./data/sessions              # file-based fallback (no Redis needed)
SESSION_TTL_SECONDS=7200                 # 2 hours
MEMORY_WINDOW_SIZE=10                    # last N turns kept in context

# ── Agent Pipeline ─────────────────────────────────────────────────────────
MAX_AGENT_ITERATIONS=10
MAX_FLOW_DURATION_SECONDS=120
AGENT_RETRY_ATTEMPTS=3
HUMAN_APPROVAL_THRESHOLD=0.70            # critic score below this → human review

# ── API Server ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_PER_MINUTE=10

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Observability ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development                  # development | production
OTEL_EXPORTER_OTLP_ENDPOINT=           # leave blank to use console exporter
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=                       # LangSmith key (optional)

# ── Failed Flow Storage ────────────────────────────────────────────────────
FAILED_FLOWS_DIR=./data/failed_flows
