# ══════════════════════════════════════════════════════════════════════════════
#  Healthcare Triage Agent — Environment Configuration
#  Copy to .env and fill in your values before running.
#
#  SWITCHING PROVIDERS (the only line you need to change):
#    LLM_PROVIDER=anthropic   → Claude API  (cloud, best quality, ~$3/M tokens)
#    LLM_PROVIDER=llamacpp    → llama.cpp   (local, zero API cost, needs 6-8GB RAM)
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider Selection ────────────────────────────────────────────────────
LLM_PROVIDER=anthropic

# ── Anthropic Settings (used when LLM_PROVIDER=anthropic) ────────────────────
ANTHROPIC_API_KEY=your_key_here
LLM_MODEL=claude-sonnet-4-20250514

# ── llama.cpp Settings (used when LLM_PROVIDER=llamacpp) ─────────────────────
#
# Step 1: Download llama.cpp
#   git clone https://github.com/ggerganov/llama.cpp
#   cd llama.cpp && cmake -B build && cmake --build build -j $(nproc)
#
# Step 2: Download a model (pick one based on your RAM):
#   6 GB RAM  → llama-3.1-8b-instruct.Q4_K_M.gguf  (good quality, recommended)
#   8 GB RAM  → llama-3.1-8b-instruct.Q8_0.gguf     (better quality)
#   4 GB RAM  → phi-3-mini-4k-instruct.Q4_K_M.gguf  (lighter, faster)
#
#   Download from: https://huggingface.co/bartowski
#   Or run:  python scripts/download_model.py --model llama3.1-8b-q4
#
# Step 3: Start the server (run this in a separate terminal):
#   ./build/bin/llama-server \
#     -m models/llama-3.1-8b-instruct.Q4_K_M.gguf \
#     --host 0.0.0.0 --port 8080 \
#     --n-gpu-layers 0 \
#     --threads 4 \
#     --ctx-size 4096
#
# Step 4: Switch provider:
#   LLM_PROVIDER=llamacpp  (change line above)
#
LLAMACPP_BASE_URL=http://localhost:8080
LLAMACPP_MODEL=llama-3.1-8b-instruct
LLAMACPP_N_CTX=4096
LLAMACPP_N_THREADS=4
LLAMACPP_N_GPU_LAYERS=0

# ── Shared LLM Settings (apply to both providers) ─────────────────────────────
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# ── Vector Store (local ChromaDB — no cloud needed) ───────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=medical_guidelines

# ── Session Memory ─────────────────────────────────────────────────────────────
SESSION_DIR=./data/sessions
SESSION_TTL_SECONDS=7200
MEMORY_WINDOW_SIZE=10


# ── Supabase Configuration  ─────────────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here


# ── Agent Pipeline ─────────────────────────────────────────────────────────────
MAX_AGENT_ITERATIONS=10
MAX_FLOW_DURATION_SECONDS=120
AGENT_RETRY_ATTEMPTS=3
HUMAN_APPROVAL_THRESHOLD=0.70

# ── API Server ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_PER_MINUTE=10

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Observability ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# ── Storage ────────────────────────────────────────────────────────────────────
FAILED_FLOWS_DIR=./data/failed_flows
